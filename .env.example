# Sicherheits- und Login-Konfiguration
# SECRET_KEY: mindestens 32 Zeichen inkl. Klein-/Großbuchstabe, Zahl und Sonderzeichen.
# Beispiel zum Erzeugen: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=__SET_A_SECURE_SECRET_KEY_MIN_32_CHARS__

# ADMIN_USERNAME: mindestens 3 Zeichen, kein Standardwert wie "admin".
ADMIN_USERNAME=__SET_A_NON_DEFAULT_ADMIN_USERNAME__

# ADMIN_PASSWORD: mindestens 12 Zeichen inkl. Klein-/Großbuchstabe, Zahl und Sonderzeichen.
ADMIN_PASSWORD=__SET_A_STRONG_ADMIN_PASSWORD_MIN_12_CHARS__

# Datenbank (SQLite im Persistenz-Volume app_data)
DATABASE_URL=sqlite:////data/meterweb.db

# Provider / Lokalisierung
WEATHER_PROVIDER=brightsky
WEATHER_BASE_URL=https://api.brightsky.dev
DEFAULT_LOCALE=de-DE
DEFAULT_TIMEZONE=Europe/Berlin
